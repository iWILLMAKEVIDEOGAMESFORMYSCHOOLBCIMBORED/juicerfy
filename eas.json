import React, { useState, useCallback, useRef } from 'react';
import {
  View, Text, TouchableOpacity, StyleSheet, Dimensions,
  Modal, Image, Animated, PanResponder, ScrollView,
} from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import { Ionicons } from '@expo/vector-icons';
import YoutubeIframe from 'react-native-youtube-iframe';
import { useMusic } from '../context/MusicContext';
import { formatDuration } from '../data/songs';
import { useSafeAreaInsets } from 'react-native-safe-area-context';

const { width, height } = Dimensions.get('window');

export default function FullPlayer() {
  const {
    currentSong, isPlaying, togglePlay, playNext, playPrev,
    playerExpanded, setPlayerExpanded, queue, playSong,
    toggleLike, isLiked,
  } = useMusic();
  const [ytReady, setYtReady] = useState(false);
  const [currentTime, setCurrentTime] = useState(0);
  const [showQueue, setShowQueue] = useState(false);
  const insets = useSafeAreaInsets();

  const onStateChange = useCallback((state) => {
    if (state === 'ended') {
      playNext();
    }
  }, [playNext]);

  if (!currentSong || !playerExpanded) return null;

  const likedSong = isLiked(currentSong.id);

  return (
    <Modal
      visible={playerExpanded}
      animationType="slide"
      presentationStyle="fullScreen"
      statusBarTranslucent
    >
      <LinearGradient
        colors={['#1A0A2E', '#0D0D1A', '#0A0A0F']}
        style={[styles.container, { paddingTop: insets.top, paddingBottom: insets.bottom }]}
      >
        {/* Header */}
        <View style={styles.header}>
          <TouchableOpacity onPress={() => setPlayerExpanded(false)} style={styles.downBtn}>
            <Ionicons name="chevron-down" size={28} color="#fff" />
          </TouchableOpacity>
          <View style={styles.headerCenter}>
            <Text style={styles.nowPlaying}>NOW PLAYING</Text>
            {currentSong.type === 'unreleased' && (
              <View style={styles.vaultBadge}>
                <Text style={styles.vaultBadgeText}>🔒 VAULT</Text>
              </View>
            )}
          </View>
          <TouchableOpacity onPress={() => setShowQueue(!showQueue)} style={styles.queueBtn}>
            <Ionicons name="list" size={22} color="#9B59B6" />
          </TouchableOpacity>
        </View>

        {!showQueue ? (
          <ScrollView showsVerticalScrollIndicator={false}>
            {/* Album Art */}
            <View style={styles.artContainer}>
              <Image source={{ uri: currentSong.albumArt }} style={styles.art} />
              <View style={styles.artGlow} />
            </View>

            {/* YouTube Player (hidden, audio only concept) */}
            <View style={styles.ytContainer}>
              <YoutubeIframe
                height={200}
                width={width - 32}
                videoId={currentSong.videoId}
                play={isPlaying}
                onChangeState={onStateChange}
                onReady={() => setYtReady(true)}
                webViewStyle={{ opacity: 0.01 }}
                initialPlayerParams={{
                  controls: false,
                  modestbranding: true,
                  rel: false,
                  showinfo: false,
                }}
              />
            </View>

            {/* Song Info */}
            <View style={styles.songInfo}>
              <View style={styles.songInfoLeft}>
                <Text style={styles.songTitle} numberOfLines={1}>{currentSong.title}</Text>
                <Text style={styles.songArtist}>Juice WRLD</Text>
                <Text style={styles.songAlbum}>{currentSong.album} • {currentSong.year}</Text>
              </View>
              <TouchableOpacity onPress={() => toggleLike(currentSong.id)} style={styles.likeBtn}>
                <Ionicons
                  name={likedSong ? 'heart' : 'heart-outline'}
                  size={28}
                  color={likedSong ? '#9B59B6' : '#666'}
                />
              </TouchableOpacity>
            </View>

            {/* Progress Bar (visual) */}
            <View style={styles.progressSection}>
              <View style={styles.progressBar}>
                <View style={[styles.progressFill, { width: '35%' }]} />
                <View style={styles.progressThumb} />
              </View>
              <View style={styles.progressTimes}>
                <Text style={styles.progressTime}>1:23</Text>
                <Text style={styles.progressTime}>-{formatDuration(Math.floor(currentSong.duration * 0.65))}</Text>
              </View>
            </View>

            {/* Controls */}
            <View style={styles.controls}>
              <TouchableOpacity onPress={playPrev} style={styles.controlBtn}>
                <Ionicons name="play-skip-back" size={26} color="#fff" />
              </TouchableOpacity>

              <TouchableOpacity
                onPress={togglePlay}
                style={styles.playBtnLarge}
              >
                <LinearGradient
                  colors={['#9B59B6', '#6C3483']}
                  style={styles.playBtnGradient}
                >
                  <Ionicons
                    name={isPlaying ? 'pause' : 'play'}
                    size={32}
                    color="#fff"
                    style={isPlaying ? {} : { marginLeft: 4 }}
                  />
                </LinearGradient>
              </TouchableOpacity>

              <TouchableOpacity onPress={playNext} style={styles.controlBtn}>
                <Ionicons name="play-skip-forward" size={26} color="#fff" />
              </TouchableOpacity>
            </View>

            {/* Extra Controls */}
            <View style={styles.extraControls}>
              <TouchableOpacity style={styles.extraBtn}>
                <Ionicons name="shuffle" size={22} color="#666" />
              </TouchableOpacity>
              <TouchableOpacity style={styles.extraBtn}>
                <Ionicons name="repeat" size={22} color="#666" />
              </TouchableOpacity>
              <TouchableOpacity style={styles.extraBtn}>
                <Ionicons name="share-outline" size={22} color="#666" />
              </TouchableOpacity>
              <TouchableOpacity
                style={styles.extraBtn}
                onPress={() => {
                  // Open on YouTube
                }}
              >
                <Ionicons name="logo-youtube" size={22} color="#666" />
              </TouchableOpacity>
            </View>
          </ScrollView>
        ) : (
          // Queue View
          <View style={styles.queueView}>
            <Text style={styles.queueTitle}>Up Next</Text>
            <ScrollView showsVerticalScrollIndicator={false}>
              {queue.map((song, index) => (
                <TouchableOpacity
                  key={song.id}
                  style={[styles.queueItem, currentSong.id === song.id && styles.queueItemActive]}
                  onPress={() => playSong(song, queue)}
                >
                  <Image source={{ uri: song.albumArt }} style={styles.queueArt} />
                  <View style={styles.queueInfo}>
                    <Text style={[styles.queueSongTitle, currentSong.id === song.id && styles.queueSongTitleActive]} numberOfLines={1}>
                      {song.title}
                    </Text>
                    <Text style={styles.queueSongMeta}>{song.year} • {formatDuration(song.duration)}</Text>
                  </View>
                  {currentSong.id === song.id && (
                    <Ionicons name="musical-notes" size={16} color="#9B59B6" />
                  )}
                </TouchableOpacity>
              ))}
            </ScrollView>
          </View>
        )}
      </LinearGradient>
    </Modal>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1 },

  header: {
    flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between',
    paddingHorizontal: 16, paddingVertical: 12,
  },
  downBtn: { width: 36, height: 36, alignItems: 'center', justifyContent: 'center' },
  headerCenter: { alignItems: 'center' },
  nowPlaying: { color: '#888', fontSize: 11, fontWeight: '700', letterSpacing: 1.5 },
  vaultBadge: { backgroundColor: 'rgba(155,89,182,0.3)', borderRadius: 8, paddingHorizontal: 8, paddingVertical: 3, marginTop: 4 },
  vaultBadgeText: { color: '#D7BDE2', fontSize: 10, fontWeight: '700' },
  queueBtn: { width: 36, height: 36, alignItems: 'center', justifyContent: 'center' },

  artContainer: { alignItems: 'center', marginTop: 20, marginBottom: 30, position: 'relative' },
  art: { width: width - 80, height: width - 80, borderRadius: 20, shadowColor: '#9B59B6', shadowOffset: { width: 0, height: 8 }, shadowOpacity: 0.5, shadowRadius: 20 },
  artGlow: {
    position: 'absolute', width: width - 80, height: width - 80, borderRadius: 20,
    shadowColor: '#9B59B6', shadowOffset: { width: 0, height: 0 }, shadowOpacity: 0.4, shadowRadius: 30,
    backgroundColor: 'transparent',
  },

  ytContainer: { height: 1, overflow: 'hidden', marginBottom: 4 },

  songInfo: { flexDirection: 'row', alignItems: 'flex-start', paddingHorizontal: 24, marginBottom: 24 },
  songInfoLeft: { flex: 1 },
  songTitle: { fontSize: 24, fontWeight: '800', color: '#fff', marginBottom: 4 },
  songArtist: { fontSize: 16, color: '#9B59B6', fontWeight: '600', marginBottom: 2 },
  songAlbum: { fontSize: 13, color: '#666' },
  likeBtn: { padding: 8, marginTop: 4 },

  progressSection: { paddingHorizontal: 24, marginBottom: 32 },
  progressBar: { height: 4, backgroundColor: '#2A2A35', borderRadius: 2, marginBottom: 8, position: 'relative' },
  progressFill: { height: '100%', backgroundColor: '#9B59B6', borderRadius: 2 },
  progressThumb: { position: 'absolute', top: -5, left: '35%', width: 14, height: 14, borderRadius: 7, backgroundColor: '#fff' },
  progressTimes: { flexDirection: 'row', justifyContent: 'space-between' },
  progressTime: { color: '#666', fontSize: 12 },

  controls: { flexDirection: 'row', alignItems: 'center', justifyContent: 'center', gap: 32, marginBottom: 28 },
  controlBtn: { width: 50, height: 50, alignItems: 'center', justifyContent: 'center' },
  playBtnLarge: { shadowColor: '#9B59B6', shadowOffset: { width: 0, height: 4 }, shadowOpacity: 0.5, shadowRadius: 12 },
  playBtnGradient: { width: 72, height: 72, borderRadius: 36, alignItems: 'center', justifyContent: 'center' },

  extraControls: { flexDirection: 'row', justifyContent: 'center', gap: 28, paddingBottom: 20 },
  extraBtn: { width: 44, height: 44, alignItems: 'center', justifyContent: 'center', backgroundColor: '#1A1A24', borderRadius: 12 },

  // Queue
  queueView: { flex: 1, paddingHorizontal: 16 },
  queueTitle: { fontSize: 20, fontWeight: '700', color: '#fff', marginBottom: 16, marginTop: 8 },
  queueItem: { flexDirection: 'row', alignItems: 'center', paddingVertical: 8, borderRadius: 10, marginBottom: 2 },
  queueItemActive: { backgroundColor: 'rgba(155,89,182,0.15)' },
  queueArt: { width: 44, height: 44, borderRadius: 8, marginRight: 12 },
  queueInfo: { flex: 1 },
  queueSongTitle: { color: '#aaa', fontSize: 14, fontWeight: '600', marginBottom: 2 },
  queueSongTitleActive: { color: '#D7BDE2' },
  queueSongMeta: { color: '#555', fontSize: 11 },
});
